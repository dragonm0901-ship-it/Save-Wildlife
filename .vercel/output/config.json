{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/tickets",
      "dest": "/tickets"
    },
    {
      "src": "/terms-conditions",
      "dest": "/terms-conditions"
    },
    {
      "src": "/services",
      "dest": "/services"
    },
    {
      "src": "/privacy-policy",
      "dest": "/privacy-policy"
    },
    {
      "src": "/news",
      "dest": "/news"
    },
    {
      "src": "/inquiry",
      "dest": "/inquiry"
    },
    {
      "src": "/faq",
      "dest": "/faq"
    },
    {
      "src": "/events",
      "dest": "/events"
    },
    {
      "src": "/donation",
      "dest": "/donation"
    },
    {
      "src": "/contact",
      "dest": "/contact"
    },
    {
      "src": "/checkout",
      "dest": "/checkout"
    },
    {
      "src": "/auth/signup",
      "dest": "/auth/signup"
    },
    {
      "src": "/auth/login",
      "dest": "/auth/login"
    },
    {
      "src": "/api/tickets",
      "dest": "/api/tickets"
    },
    {
      "src": "/api/testimonials",
      "dest": "/api/testimonials"
    },
    {
      "src": "/api/team",
      "dest": "/api/team"
    },
    {
      "src": "/api/services",
      "dest": "/api/services"
    },
    {
      "src": "/api/faqs",
      "dest": "/api/faqs"
    },
    {
      "src": "/api/events",
      "dest": "/api/events"
    },
    {
      "src": "/api/donations/content",
      "dest": "/api/donations/content"
    },
    {
      "src": "/api/contact",
      "dest": "/api/contact"
    },
    {
      "src": "/api/blog",
      "dest": "/api/blog"
    },
    {
      "src": "/api/animals",
      "dest": "/api/animals"
    },
    {
      "src": "/animals-birds",
      "dest": "/animals-birds"
    },
    {
      "src": "/about",
      "dest": "/about"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/services/(?<slug>[^/]+)",
      "dest": "/services/[slug]"
    },
    {
      "src": "/events/(?<slug>[^/]+)",
      "dest": "/events/[slug]"
    },
    {
      "src": "/blogs/(?<slug>[^/]+)",
      "dest": "/blogs/[slug]"
    },
    {
      "src": "/api/services/(?<slug>[^/]+)",
      "dest": "/api/services/[slug]"
    },
    {
      "src": "/api/events/(?<slug>[^/]+)",
      "dest": "/api/events/[slug]"
    },
    {
      "src": "/api/blog/(?<slug>[^/]+)",
      "dest": "/api/blog/[slug]"
    },
    {
      "src": "/api/animals/(?<slug>[^/]+)",
      "dest": "/api/animals/[slug]"
    },
    {
      "src": "/animals/(?<slug>[^/]+)",
      "dest": "/animals/[slug]"
    },
    {
      "src": "/_ipx/(?:.*)",
      "dest": "/_ipx/[...]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
